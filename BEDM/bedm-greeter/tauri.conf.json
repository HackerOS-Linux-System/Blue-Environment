{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bedm-greeter",
  "version": "1.0.0",
  "identifier": "org.legendaryos.bedm-greeter",
  "build": {
    "beforeDevCommand": "cd ../bedm-ui && npm run dev",
    "beforeBuildCommand": "mkdir -p icons && cp ../../images/icon.png icons/icon.png && cd ../bedm-ui && npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../bedm-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "BEDM Login",
        "width": 1280,
        "height": 800,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": false
    }
  }
}
