// ── Pojedyncza ikona w docku ─────────────────────────────
component DockIcon inherits Rectangle {
    callback clicked();
    in property <image>  icon;
    in property <string> app-name;
    in property <bool>   running: false;
    in property <bool>   active:  false;

    width: 52px; height: 52px;
    border-radius: 13px;
    background: ta.has-hover ? #ffffff14 : (active ? #ffffff1a : transparent);
    animate background { duration: 120ms; }

    // bounce jest w px — length, nie float
    property <length> bounce: 0px;
    animate bounce { duration: 180ms; easing: ease-out; }

    ta := TouchArea {
        clicked => {
            root.bounce = -8px;
            root.clicked();
        }
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.up) {
                root.bounce = 0px;
            }
        }
    }

    Image {
        source: root.icon;
        width: 36px; height: 36px;
        image-fit: contain;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2 + root.bounce;
        animate y { duration: 180ms; easing: ease-out; }
    }

    if root.running: Rectangle {
        width: root.active ? 14px : 5px;
        height: 3px; border-radius: 2px;
        background: root.active ? #3d8ef0 : #ffffff55;
        x: (parent.width - self.width) / 2;
        y: parent.height - 5px;
        animate width      { duration: 200ms; easing: ease-out; }
        animate background { duration: 200ms; }
    }

    if ta.has-hover: Rectangle {
        width: tooltip-text.preferred-width + 16px;
        height: 24px; border-radius: 6px;
        background: #0d1117ee;
        border-width: 1px; border-color: #1e2d4a;
        x: (parent.width - self.width) / 2;
        y: -30px;
        tooltip-text := Text {
            text: root.app-name;
            color: #e8f0fe; font-size: 11px; font-weight: 600;
            x: 8px; y: 4px;
        }
    }
}

// ── Eksportowane typy ─────────────────────────────────────
export struct DockEntry {
    exec:    string,
    name:    string,
    icon:    image,
    running: bool,
    active:  bool,
}

export component BlueDock inherits Window {
    title: "Blue Dock";
    background: transparent;
    no-frame: true;
    always-on-top: false;

    callback app-clicked(string);
    callback dock-hovered(bool);

    in property <[DockEntry]> entries: [];
    in-out property <bool>  visible-dock:  true;
    in-out property <float> hide-progress: 0.0;

    width: 800px; height: 72px;

    animate hide-progress { duration: 280ms; easing: ease-in-out; }

    Rectangle {
        y: root.hide-progress * 66px;
        animate y { duration: 280ms; easing: ease-in-out; }
        width: dock-row.preferred-width + 24px;
        height: 62px;
        x: (root.width - self.width) / 2;

        Rectangle {
            width: 100%; height: 100%;
            border-radius: 18px;
            background: #0d1117cc;
            border-width: 1px; border-color: #ffffff14;
            Rectangle {
                y: 0; x: 8px;
                width: parent.width - 16px; height: 1px;
                background: @linear-gradient(90deg, transparent 0%, #ffffff22 50%, transparent 100%);
            }
        }

        hover-area := TouchArea {
            width: 100%; height: 100%;
            mouse-cursor: default;
            pointer-event(ev) => {
                if (ev.kind == PointerEventKind.move) {
                    root.dock-hovered(true);
                }
            }
        }

        dock-row := HorizontalLayout {
            padding-left: 12px; padding-right: 12px;
            padding-top: 5px; padding-bottom: 5px;
            spacing: 4px; alignment: center;
            y: 0; x: 0; height: 62px;

            for entry[i] in root.entries: DockIcon {
                icon:     entry.icon;
                app-name: entry.name;
                running:  entry.running;
                active:   entry.active;
                clicked => { root.app-clicked(entry.exec); }
            }
        }
    }
}
