import { ScrollView, Slider, Switch, ComboBox } from "std-widgets.slint";

// ── Nav item ─────────────────────────────────────────────
component NavItem inherits Rectangle {
    callback clicked();
    in property <string> ico;
    in property <string> label;
    in property <bool>   active;
    height: 40px; border-radius: 8px;
    background:   active ? #3d8ef018 : transparent;
    border-width: active ? 1px : 0px;
    border-color: active ? #3d8ef040 : transparent;
    animate background { duration: 120ms; }
    states [ hovered when t.has-hover && !active: { background: #1a2540; } ]
    t := TouchArea { clicked => { root.clicked(); } }
    HorizontalLayout {
        padding-left: 12px; padding-right: 12px; spacing: 10px;
        Text { text: ico;   font-size: 16px; vertical-alignment: center; width: 22px; }
        Text { text: label; color: active ? #e8f0fe : #8899bb; font-size: 13px; vertical-alignment: center; animate color { duration: 120ms; } }
    }
}

// ── Section header ────────────────────────────────────────
component SectionHead inherits Text {
    in property <string> title;
    text: title; color: #3d8ef0; font-size: 11px; font-weight: 700;
    letter-spacing: 1.5px; height: 28px; vertical-alignment: center;
}

// ── Settings row ─────────────────────────────────────────
component Row inherits Rectangle {
    in property <string> label;
    in property <string> hint: "";
    height: hint == "" ? 44px : 58px;
    border-radius: 8px; background: #0d1117; border-width: 1px; border-color: #1e2d4a;
    HorizontalLayout {
        padding-left: 16px; padding-right: 16px; spacing: 12px;
        VerticalLayout {
            alignment: center; horizontal-stretch: 1;
            Text { text: label; color: #e8f0fe; font-size: 13px; }
            if hint != "": Text { text: hint; color: #8899bb; font-size: 11px; }
        }
        @children
    }
}

// ── Wallpaper thumbnail ───────────────────────────────────
component WpThumb inherits Rectangle {
    callback clicked();
    in property <image>  thumb;
    in property <string> name;
    in property <bool>   selected;
    width: 160px; height: 100px; border-radius: 8px; clip: true;
    border-width: selected ? 2px : 1px;
    border-color: selected ? #3d8ef0 : #1e2d4a;
    animate border-color { duration: 150ms; }
    states [ hovered when t.has-hover && !selected: { border-color: #3d8ef060; } ]
    t := TouchArea { clicked => { root.clicked(); } }
    Image { source: thumb; width: 100%; height: 100%; image-fit: cover; }
    if selected: Rectangle {
        x: parent.width - 26px; y: 6px; width: 20px; height: 20px; border-radius: 10px; background: #3d8ef0;
        Text { text: "✓"; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
    }
}

// ═══════════════════════════════════════════════════════════
// SETTINGS WINDOW
// ═══════════════════════════════════════════════════════════
export component BlueSettings inherits Window {
    title: "Blue Settings";
    background: #080d14;
    min-width: 960px; min-height: 640px;
    preferred-width: 1100px; preferred-height: 720px;

    in-out property <int>    active-page:        0;
    in-out property <string> current-wallpaper:  "";
    in-out property <string> current-theme:      "Default";
    in-out property <string> active-category:    "All";

    in property <[{path: string, thumb: image, name: string}]> wallpapers: [];
    in property <[string]> themes:   ["Default", "Dark Cosmos", "Blue Steel", "Nebula"];
    in property <float>  window-blur:       20.0;
    in property <bool>   enable-animations: true;
    in property <bool>   enable-blur:       true;
    in property <bool>   enable-shadows:    true;
    in property <float>  corner-radius:     10.0;
    in property <float>  scale-factor:      1.0;
    in property <float>  master-volume:     0.75;

    callback page-changed(int);
    callback wallpaper-selected(string);
    callback theme-changed(string);
    callback blur-changed(float);
    callback animations-toggled(bool);
    callback blur-toggled(bool);
    callback shadows-toggled(bool);
    callback corner-radius-changed(float);
    callback scale-changed(float);
    callback volume-changed(float);

    HorizontalLayout {

        // ─── LEFT SIDEBAR ─────────────────────────────────────
        // IMPORTANT: border-width with CSS shorthand breaks Slint
        // We use a 1px Rectangle as the right border line instead.
        Rectangle {
            width: 220px; background: #0a0e16;

            // Right border — single 1px Rectangle
            Rectangle { x: 219px; y: 0; width: 1px; height: 100%; background: #1e2d4a; }

            VerticalLayout {
                padding: 16px; spacing: 4px;

                // Logo
                HorizontalLayout {
                    padding-bottom: 12px; spacing: 8px; alignment: start;
                    Rectangle {
                        width: 32px; height: 32px; border-radius: 8px;
                        background: @linear-gradient(135deg, #3d8ef0 0%, #5b2ea6 100%);
                        Text { text: "BE"; color: white; font-size: 11px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    VerticalLayout {
                        alignment: center;
                        Text { text: "Blue Environment"; color: #e8f0fe; font-size: 12px; font-weight: 600; }
                        Text { text: "Settings";          color: #8899bb; font-size: 11px; }
                    }
                }

                NavItem { ico: "🎨"; label: "Appearance";        active: active-page == 0; clicked => { root.active-page = 0; root.page-changed(0); } }
                NavItem { ico: "🖥";  label: "Display";           active: active-page == 1; clicked => { root.active-page = 1; root.page-changed(1); } }
                NavItem { ico: "⌨";  label: "Keyboard & Mouse";  active: active-page == 2; clicked => { root.active-page = 2; root.page-changed(2); } }
                NavItem { ico: "🔊"; label: "Sound";              active: active-page == 3; clicked => { root.active-page = 3; root.page-changed(3); } }
                NavItem { ico: "🌐"; label: "Network";            active: active-page == 4; clicked => { root.active-page = 4; root.page-changed(4); } }
                NavItem { ico: "🔋"; label: "Power";              active: active-page == 5; clicked => { root.active-page = 5; root.page-changed(5); } }
                NavItem { ico: "👤"; label: "Users";              active: active-page == 6; clicked => { root.active-page = 6; root.page-changed(6); } }
                NavItem { ico: "🔒"; label: "Privacy & Security"; active: active-page == 7; clicked => { root.active-page = 7; root.page-changed(7); } }
                NavItem { ico: "ℹ";  label: "About HackerOS";    active: active-page == 8; clicked => { root.active-page = 8; root.page-changed(8); } }

                Rectangle { vertical-stretch: 1; }
                Text { text: "Blue Environment 0.1.0"; color: #2a3a55; font-size: 10px; horizontal-alignment: center; }
            }
        }

        // ─── RIGHT CONTENT ────────────────────────────────────
        ScrollView {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 28px; spacing: 20px;

                // ── PAGE 0: APPEARANCE ─────────────────────────
                if active-page == 0: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Appearance"; color: #e8f0fe; font-size: 22px; font-weight: 300; }

                    SectionHead { title: "WALLPAPER"; }

                    Rectangle {
                        height: 240px; border-radius: 10px; background: #0d1117;
                        border-width: 1px; border-color: #1e2d4a; clip: true;
                        ScrollView {
                            HorizontalLayout {
                                padding: 16px; spacing: 12px; alignment: start;
                                for wp in wallpapers: WpThumb {
                                    thumb: wp.thumb; name: wp.name; selected: wp.path == current-wallpaper;
                                    clicked => { root.current-wallpaper = wp.path; root.wallpaper-selected(wp.path); }
                                }
                            }
                        }
                    }
                    Text { text: "Wallpapers from /usr/share/wallpapers/ • PNG, JPG, WebP"; color: #3a4d6a; font-size: 11px; }

                    SectionHead { title: "THEME"; }
                    Row { label: "Color Theme"; hint: "Choose the appearance theme";
                        ComboBox { model: root.themes; current-value: root.current-theme; selected(v) => { root.theme-changed(v); } }
                    }

                    SectionHead { title: "EFFECTS"; }
                    Row { label: "Window Animations"; hint: "Animate open/close/minimize";
                        Switch { checked: root.enable-animations; toggled => { root.animations-toggled(self.checked); } }
                    }
                    Row { label: "Background Blur"; hint: "Blur behind translucent windows";
                        Switch { checked: root.enable-blur; toggled => { root.blur-toggled(self.checked); } }
                    }
                    Row { label: "Blur Radius";
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            Slider { minimum: 0; maximum: 40; value: root.window-blur; width: 140px; changed(v) => { root.blur-changed(v); } }
                            Text { text: root.window-blur + "px"; color: #8899bb; font-size: 12px; vertical-alignment: center; width: 45px; }
                        }
                    }
                    Row { label: "Drop Shadows";
                        Switch { checked: root.enable-shadows; toggled => { root.shadows-toggled(self.checked); } }
                    }
                    Row { label: "Window Corner Radius";
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            Slider { minimum: 0; maximum: 20; value: root.corner-radius; width: 140px; changed(v) => { root.corner-radius-changed(v); } }
                            Text { text: root.corner-radius + "px"; color: #8899bb; font-size: 12px; vertical-alignment: center; width: 45px; }
                        }
                    }
                }

                // ── PAGE 1: DISPLAY ────────────────────────────
                if active-page == 1: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Display"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    SectionHead { title: "SCALING"; }
                    Row { label: "Display Scale"; hint: "Scale UI for HiDPI";
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            Slider { minimum: 1; maximum: 3; value: root.scale-factor; width: 140px; changed(v) => { root.scale-changed(v); } }
                            Text { text: root.scale-factor + "×"; color: #8899bb; font-size: 12px; vertical-alignment: center; width: 40px; }
                        }
                    }
                    SectionHead { title: "MONITORS"; }
                    Rectangle {
                        height: 100px; border-radius: 10px; background: #0d1117; border-width: 1px; border-color: #1e2d4a;
                        Text { text: "Monitor detection requires compositor connection"; color: #3a4d6a; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // ── PAGE 2: KEYBOARD & MOUSE ───────────────────
                if active-page == 2: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Keyboard & Mouse"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    SectionHead { title: "KEYBOARD"; }
                    Row { label: "Keyboard Layout"; hint: "Managed via system locale";
                        Text { text: "System default"; color: #8899bb; font-size: 12px; vertical-alignment: center; }
                    }
                    SectionHead { title: "MOUSE"; }
                    Row { label: "Natural Scrolling"; Switch {} }
                    Row { label: "Pointer Speed";
                        Slider { minimum: 0; maximum: 1; value: 0.5; width: 140px; }
                    }
                }

                // ── PAGE 3: SOUND ──────────────────────────────
                if active-page == 3: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Sound"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    SectionHead { title: "OUTPUT"; }
                    Row { label: "Master Volume";
                        HorizontalLayout {
                            spacing: 12px; alignment: center;
                            Slider { minimum: 0; maximum: 1; value: root.master-volume; width: 200px; changed(v) => { root.volume-changed(v); } }
                            Text { text: Math.round(root.master-volume * 100) + "%"; color: #8899bb; font-size: 12px; vertical-alignment: center; width: 40px; }
                        }
                    }
                }

                // ── PAGE 4: NETWORK ────────────────────────────
                if active-page == 4: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Network"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    Rectangle {
                        height: 100px; border-radius: 10px; background: #0d1117; border-width: 1px; border-color: #1e2d4a;
                        Text { text: "Network management requires NetworkManager integration"; color: #3a4d6a; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // ── PAGE 5: POWER ──────────────────────────────
                if active-page == 5: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Power"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    SectionHead { title: "POWER MANAGEMENT"; }
                    Row { label: "Suspend on idle"; hint: "Auto-suspend after inactivity"; Switch {} }
                    Row { label: "Screen brightness"; Slider { minimum: 0; maximum: 100; value: 80; width: 180px; } }
                }

                // ── PAGE 6: USERS ──────────────────────────────
                if active-page == 6: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Users"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    Rectangle {
                        height: 80px; border-radius: 10px; background: #0d1117; border-width: 1px; border-color: #1e2d4a;
                        Text { text: "User management requires administrator privileges"; color: #3a4d6a; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // ── PAGE 7: PRIVACY ────────────────────────────
                if active-page == 7: VerticalLayout {
                    spacing: 20px;
                    Text { text: "Privacy & Security"; color: #e8f0fe; font-size: 22px; font-weight: 300; }
                    SectionHead { title: "SCREEN LOCK"; }
                    Row { label: "Automatic Screen Lock"; Switch { checked: true; } }
                    Row { label: "Lock on suspend";       Switch { checked: true; } }
                }

                // ── PAGE 8: ABOUT ──────────────────────────────
                if active-page == 8: VerticalLayout {
                    spacing: 24px;
                    Text { text: "About HackerOS"; color: #e8f0fe; font-size: 22px; font-weight: 300; }

                    HorizontalLayout {
                        alignment: center;
                        Rectangle {
                            width: 80px; height: 80px; border-radius: 20px;
                            background: @linear-gradient(135deg, #3d8ef0 0%, #5b2ea6 100%);
                            Text { text: "BE"; color: white; font-size: 28px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Blue Environment";             color: #e8f0fe; font-size: 24px; font-weight: 300; horizontal-alignment: center; }
                        Text { text: "Version 0.1.0 · HackerOS";    color: #8899bb; font-size: 14px; horizontal-alignment: center; }
                        Text { text: "A modern desktop for HackerOS"; color: #3a4d6a; font-size: 13px; horizontal-alignment: center; }
                    }

                    Rectangle { height: 1px; background: #1e2d4a; }

                    VerticalLayout {
                        spacing: 10px;
                        for info in [
                            {label: "Desktop Environment", value: "Blue Environment 0.1.0"},
                            {label: "Compositor",          value: "Smithay (Wayland)"},
                            {label: "UI Framework",        value: "Slint 1.5"},
                            {label: "Language",            value: "Rust"},
                            {label: "License",             value: "GPL-3.0"},
                            {label: "Session Type",        value: "Wayland"},
                        ]: HorizontalLayout {
                            padding-left: 20px; spacing: 0px;
                            Text { text: info.label; color: #8899bb; font-size: 13px; width: 220px; }
                            Text { text: info.value; color: #e8f0fe; font-size: 13px; }
                        }
                    }
                }

            }
        }
    }
}
