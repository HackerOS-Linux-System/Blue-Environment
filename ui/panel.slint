import { ScrollView } from "std-widgets.slint";

// ── Eksportowane struktury danych (widoczne w Rust) ───────
export struct WindowItem {
    id:        int,
    title:     string,
    focused:   bool,
    minimized: bool,
}

export struct TrayEntry {
    name: string,
    icon: string,
}

export struct CalDay {
    day:         int,
    other-month: bool,
    today:       bool,
}

// ── Launcher button (3×3 dot grid) ───────────────────────
component LauncherBtn inherits Rectangle {
    callback clicked();
    in property <bool> active: false;
    width: 48px; height: 36px; border-radius: 7px;
    background: active ? #2d3d66 : transparent;
    animate background { duration: 120ms; }
    states [ hovered when t.has-hover && !active: { background: #1a2540; } ]
    t := TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        alignment: center; padding: 9px; spacing: 3px;
        for _r in [0, 1, 2]: HorizontalLayout {
            alignment: center; spacing: 3px;
            for _c in [0, 1, 2]: Rectangle {
                width: 3px; height: 3px; border-radius: 1px; background: #3d8ef0;
            }
        }
    }
}

// ── Workspace button ──────────────────────────────────────
component WsBtn inherits Rectangle {
    callback clicked();
    in property <int>  index;
    in property <bool> active;
    width: 26px; height: 26px; border-radius: 5px;
    background:   active ? #3d8ef0 : transparent;
    border-width: 1px; border-color: active ? #3d8ef0 : #1e2d4a;
    animate background { duration: 150ms; }
    states [ hovered when t.has-hover && !active: { background: #1a2540; } ]
    t := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: index + 1; color: active ? #fff : #8899bb;
        font-size: 11px; font-weight: 600;
        horizontal-alignment: center; vertical-alignment: center;
    }
}

// ── Taskbar button (podgląd okna) ─────────────────────────
component TaskBtn inherits Rectangle {
    callback clicked();
    in property <string> label;
    in property <bool>   focused;
    in property <bool>   minimized;

    height: 34px; min-width: 100px; max-width: 200px; border-radius: 6px;
    background: focused ? #1a2540 : (minimized ? #111820 : transparent);
    border-width: focused ? 1px : 0px; border-color: #3d8ef040;
    animate background { duration: 120ms; }
    states [ hovered when t.has-hover && !focused: { background: #141c2e; } ]
    t := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 8px; padding-right: 8px; spacing: 5px; alignment: center;
        // Kolorowy pasek po lewej (aktywne = niebieski, zminimalizowane = szary)
        Rectangle {
            width: 2px; height: 18px; border-radius: 1px;
            background: focused ? #3d8ef0 : (minimized ? #3a4d6a : transparent);
        }
        Text {
            text: label; overflow: elide; vertical-alignment: center;
            color: focused ? #e8f0fe : (minimized ? #5a6d8a : #8899bb);
            font-size: 12px;
        }
    }
    // Dolny indykator dla aktywnego okna
    if focused: Rectangle {
        x: parent.width / 2 - 8px; y: parent.height - 2px;
        width: 16px; height: 2px; border-radius: 1px; background: #3d8ef0;
    }
}

// ── System tray icon ──────────────────────────────────────
component TrayIcon inherits Rectangle {
    callback clicked();
    in property <string> ico;
    in property <string> tooltip;
    width: 22px; height: 22px; border-radius: 5px; background: transparent;
    animate background { duration: 100ms; }
    states [ hovered when t.has-hover: { background: #1a2540; } ]
    t := TouchArea { clicked => { root.clicked(); } }
    Text { text: ico; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
}

// ── Separator ─────────────────────────────────────────────
component Sep inherits Rectangle {
    width: 1px; height: 22px; background: #1e2d4a; opacity: 0.7;
}

// ── Wskaźnik sieci ────────────────────────────────────────
component NetworkIndicator inherits Rectangle {
    callback clicked();
    in property <bool>   connected:  true;
    in property <bool>   wifi:       true;
    in property <string> ssid:       "";
    in property <int>    strength:   100;  // 0-100

    width: 52px; height: 34px; border-radius: 6px; background: transparent;
    animate background { duration: 100ms; }
    states [ hovered when nt.has-hover: { background: #1a2540; } ]
    nt := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 4px; padding-right: 4px; spacing: 2px; alignment: center;
        Text {
            text: !connected ? "⊘" : (wifi ? "▲" : "⬡");
            font-size: 14px;
            color: !connected ? #ff4757 : (strength > 60 ? #3d8ef0 : (strength > 30 ? #ffc032 : #ff4757));
            vertical-alignment: center;
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: !connected ? "Off" : (wifi ? ssid : "LAN");
                color: connected ? #e8f0fe : #5a6d8a;
                font-size: 9px; overflow: elide;
            }
            if connected && wifi: Text {
                text: strength + "%";
                color: #5a6d8a; font-size: 8px;
            }
        }
    }
}

// ── Volume control ────────────────────────────────────────
component VolumeControl inherits Rectangle {
    callback clicked();
    in property <float>  volume:  0.75;
    in property <bool>   muted:   false;
    width: 46px; height: 34px; border-radius: 6px; background: transparent;
    animate background { duration: 100ms; }
    states [ hovered when vt.has-hover: { background: #1a2540; } ]
    vt := TouchArea { clicked => { root.clicked(); } }
    VerticalLayout {
        alignment: center; padding: 4px;
        Text {
            text: muted ? "🔇" : (volume > 0.65 ? "🔊" : (volume > 0.2 ? "🔉" : "🔈"));
            font-size: 13px; horizontal-alignment: center;
        }
        Text {
            text: muted ? "mute" : (Math.round(volume * 100) + "%");
            color: muted ? #ff4757 : #5a6d8a; font-size: 8px; horizontal-alignment: center;
        }
    }
}

// ── Kalendarz popup ───────────────────────────────────────
component CalendarPopup inherits Rectangle {
    in property <string> month-name:  "Styczeń 2026";
    in property <int>    today-day:   1;
    in property <[CalDay]> days: [];
    callback close();

    width: 280px; border-radius: 12px;
    background: @linear-gradient(160deg, #0d1420f8 0%, #090d18f8 100%);
    border-width: 1px; border-color: #1e2d4a;
    drop-shadow-blur: 24px; drop-shadow-color: #00000080;
    clip: true;

    // Glow line na górze
    Rectangle { y: 0; width: 100%; height: 1px; background: @linear-gradient(90deg, transparent 0%, #3d8ef044 50%, transparent 100%); }

    VerticalLayout {
        padding: 14px; spacing: 10px;

        // Nagłówek miesiąca
        HorizontalLayout {
            Text { text: "◀"; color: #3a4d6a; font-size: 12px; vertical-alignment: center; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: month-name; color: #e8f0fe; font-size: 13px; font-weight: 600; horizontal-alignment: center; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: "▶"; color: #3a4d6a; font-size: 12px; vertical-alignment: center; }
        }

        // Nagłówki dni tygodnia
        HorizontalLayout {
            spacing: 2px;
            for d in ["Pn", "Wt", "Śr", "Cz", "Pt", "Sb", "Nd"]: Rectangle {
                horizontal-stretch: 1; height: 20px;
                Text { text: d; color: #3d8ef0; font-size: 10px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
            }
        }

        Rectangle { height: 1px; background: #1e2d4a; }

        // Siatka dni
        VerticalLayout {
            spacing: 2px;
            // 6 tygodni × 7 dni = 42 komórki
            for week-start in [0, 7, 14, 21, 28, 35]: HorizontalLayout {
                spacing: 2px;
                for col in [0, 1, 2, 3, 4, 5, 6]: Rectangle {
                    horizontal-stretch: 1; height: 28px; border-radius: 6px;
                    background: (week-start + col) < days.length && days[week-start + col].today
                        ? #3d8ef0
                        : transparent;
                    animate background { duration: 100ms; }
                    states [ hovered when dt.has-hover: { background: #1a2540; } ]
                    dt := TouchArea {}
                    Text {
                        text: (week-start + col) < days.length ? days[week-start + col].day : 0;
                        color: (week-start + col) < days.length && days[week-start + col].today ? #fff
                             : ((week-start + col) < days.length && days[week-start + col].other-month ? #2a3a55
                             : #8899bb);
                        font-size: 11px; horizontal-alignment: center; vertical-alignment: center;
                    }
                }
            }
        }

        // Stopka — dziś
        HorizontalLayout {
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                height: 24px; min-width: 64px; border-radius: 6px; background: #141c2e;
                border-width: 1px; border-color: #1e2d4a;
                animate background { duration: 100ms; }
                states [ hovered when th.has-hover: { background: #1e2d4a; } ]
                th := TouchArea { clicked => { root.close(); } }
                Text { text: "Dziś"; color: #3d8ef0; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════
// GŁÓWNY PANEL
// ═══════════════════════════════════════════════════════════
export component BluePanel inherits Window {
    title: "Blue Panel";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    width: 1920px;
    height: 42px;

    // ── Callbacks ─────────────────────────────────────────
    callback launcher-clicked();
    callback workspace-clicked(int);
    callback window-clicked(int);
    callback settings-clicked();
    callback show-power-menu();
    callback notifications-clicked();
    callback clock-clicked();
    callback network-clicked();
    callback volume-clicked();
    callback tray-clicked(string);  // nazwa serwisu

    // ── Properties ────────────────────────────────────────
    in-out property <bool>   launcher-open:     false;
    in-out property <bool>   calendar-visible:  false;

    in property <string> clock-time:       "00:00";
    in property <string> clock-date:       "Pon 01 Sty";
    in property <string> calendar-month:   "Styczeń 2026";
    in property <int>    today-day:        1;
    in property <[CalDay]> calendar-days: [];

    in property <int>   active-workspace:  0;
    in property <int>   workspace-count:   4;

    in property <float> volume:            0.75;
    in property <bool>  muted:             false;

    in property <bool>   net-connected:    true;
    in property <bool>   net-wifi:         true;
    in property <string> net-ssid:         "";
    in property <int>    net-strength:     80;

    in property <int>    unread-notifs:    0;

    // Okna w taskbarze
    in property <[WindowItem]> open-windows: [];

    // System tray
    in property <[TrayEntry]> tray-items: [];

    // ── Tło panelu ────────────────────────────────────────
    Rectangle {
        width: 100%; height: 100%;
        background: @linear-gradient(180deg, #0c1118f8 0%, #090d14f8 100%);
        border-width: 0px;
        // Dolna linia
        Rectangle {
            y: parent.height - 1px; width: 100%; height: 1px;
            background: @linear-gradient(90deg,
                transparent 0%, #3d8ef030 15%,
                #1e2d4a 50%,
                #3d8ef030 85%, transparent 100%);
        }
        // Górna poświata
        Rectangle { y: 0; width: 100%; height: 1px; background: #ffffff08; }
    }

    HorizontalLayout {
        padding-left: 6px; padding-right: 6px;
        padding-top: 3px;  padding-bottom: 3px;
        spacing: 2px;

        // ── Launcher ──────────────────────────────────────
        LauncherBtn {
            active: launcher-open;
            clicked => { root.launcher-clicked(); }
        }

        Sep {}

        // ── Workspace switcher ────────────────────────────
        HorizontalLayout {
            spacing: 3px; padding-left: 4px; padding-right: 4px; alignment: center;
            for i in workspace-count: WsBtn {
                index: i; active: i == active-workspace;
                clicked => { root.workspace-clicked(i); }
            }
        }

        Sep {}

        // ── Taskbar ───────────────────────────────────────
        HorizontalLayout {
            spacing: 2px; padding-left: 6px; padding-right: 4px;
            alignment: start; horizontal-stretch: 1;

            if open-windows.length == 0: Text {
                text: "Brak okien";
                color: #2a3a55; font-size: 11px; vertical-alignment: center;
                padding-left: 4px;
            }

            for w in open-windows: TaskBtn {
                label:     w.title;
                focused:   w.focused;
                minimized: w.minimized;
                clicked => { root.window-clicked(w.id); }
            }
        }

        Sep {}

        // ── System tray ───────────────────────────────────
        if tray-items.length > 0: HorizontalLayout {
            spacing: 1px; padding-left: 4px; padding-right: 4px; alignment: center;
            for item in tray-items: TrayIcon {
                ico: item.icon;
                clicked => { root.tray-clicked(item.name); }
            }
        }
        if tray-items.length > 0: Sep {}

        // ── Powiadomienia ─────────────────────────────────
        Rectangle {
            width: 32px; height: 34px; border-radius: 6px; background: transparent;
            animate background { duration: 100ms; }
            states [ hovered when bt.has-hover: { background: #1a2540; } ]
            bt := TouchArea { clicked => { root.notifications-clicked(); } }
            Text { text: "🔔"; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
            // Badge z liczbą nieprzeczytanych
            if unread-notifs > 0: Rectangle {
                x: 18px; y: 2px; width: 14px; height: 14px; border-radius: 7px;
                background: #ff4757; border-width: 1px; border-color: #0c1118;
                Text {
                    text: unread-notifs > 9 ? "9+" : unread-notifs;
                    color: #fff; font-size: 8px; font-weight: 700;
                    horizontal-alignment: center; vertical-alignment: center;
                }
            }
        }

        // ── Sieć ──────────────────────────────────────────
        NetworkIndicator {
            connected: net-connected; wifi: net-wifi;
            ssid: net-ssid; strength: net-strength;
            clicked => { root.network-clicked(); }
        }

        // ── Głośność ──────────────────────────────────────
        VolumeControl {
            volume: volume; muted: muted;
            clicked => { root.volume-clicked(); }
        }

        // ── Ustawienia ────────────────────────────────────
        Rectangle {
            width: 30px; height: 34px; border-radius: 6px; background: transparent;
            animate background { duration: 100ms; }
            states [ hovered when st.has-hover: { background: #1a2540; } ]
            st := TouchArea { clicked => { root.settings-clicked(); } }
            Text { text: "⚙"; font-size: 14px; color: #8899bb; horizontal-alignment: center; vertical-alignment: center; }
        }

        Sep {}

        // ── Zegar + kalendarz popup ───────────────────────
        Rectangle {
            min-width: 80px; height: 34px; border-radius: 6px; background: transparent;
            animate background { duration: 100ms; }
            states [ hovered when ct.has-hover: { background: #1a2540; } ]
            ct := TouchArea {
                clicked => {
                    root.calendar-visible = !root.calendar-visible;
                    root.clock-clicked();
                }
            }
            VerticalLayout {
                alignment: center; padding-left: 6px; padding-right: 6px;
                Text { text: clock-time; color: #e8f0fe; font-size: 13px; font-weight: 600; horizontal-alignment: center; }
                Text { text: clock-date; color: #8899bb; font-size: 9px; horizontal-alignment: center; }
            }
        }

        // ── Power ─────────────────────────────────────────
        Rectangle {
            width: 28px; height: 34px; border-radius: 6px; background: transparent;
            animate background { duration: 100ms; }
            states [ hovered when pt.has-hover: { background: #ff47571a; } ]
            pt := TouchArea { clicked => { root.show-power-menu(); } }
            Text { text: "⏻"; font-size: 15px; color: #8899bb; horizontal-alignment: center; vertical-alignment: center; }
        }
    }

    // ── Kalendarz popup (nad panelem) ─────────────────────
    if calendar-visible: CalendarPopup {
        x: parent.width - 296px;
        y: 44px;  // pod panelem
        height: 320px;
        month-name:  calendar-month;
        today-day:   today-day;
        days:        calendar-days;
        close => { root.calendar-visible = false; }
    }
}
