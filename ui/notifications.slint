import { ScrollView } from "std-widgets.slint";

// ── Eksportowane struktury Rust ───────────────────────────
export struct ActionItem {
    key:   string,
    label: string,
}

export struct PopupItem {
    nid:      int,
    app-name: string,
    summary:  string,
    body:     string,
    accent:   color,
    critical: bool,
    actions:  [ActionItem],
}

export struct CenterItem {
    id:       int,
    app-name: string,
    summary:  string,
    body:     string,
    age:      string,
    accent:   color,
    critical: bool,
}

// ── Wewnętrzny popup (nie eksportowany) ──────────────────
component NotificationPopup inherits Rectangle {
    callback dismissed(int);
    callback action-invoked(int, string);

    in property <int>    nid;
    in property <string> app-name;
    in property <string> summary;
    in property <string> body;
    in property <color>  accent:   #3d8ef0;
    in property <bool>   critical: false;
    in property <[ActionItem]> actions: [];

    width: 360px;
    height: body == "" ? 72px : (actions.length > 0 ? 112px : 86px);
    border-radius: 12px;
    background: @linear-gradient(160deg, #0d1420fa 0%, #090d18f8 100%);
    border-width: 1px;
    border-color: critical ? #ff475740 : #1e2d4a;
    drop-shadow-blur: 22px;
    drop-shadow-color: #00000070;
    clip: true;

    Rectangle { x: 0; y: 0; width: 3px; height: 100%; background: accent; border-radius: 2px; }
    if critical: Rectangle { width: 100%; height: 100%; background: @linear-gradient(90deg, #ff475708 0%, transparent 50%); }

    HorizontalLayout {
        padding-left: 14px; padding-right: 10px;
        padding-top: 10px; padding-bottom: 10px;
        spacing: 10px;

        Rectangle {
            width: 36px; height: 36px; border-radius: 9px;
            background: @linear-gradient(135deg, #1a2540 0%, #222d48 100%);
            border-width: 1px; border-color: #1e2d4a;
            Text { text: "●"; color: accent; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
        }

        VerticalLayout {
            horizontal-stretch: 1; alignment: start; spacing: 2px;
            Text { text: app-name; color: #5a6d8a; font-size: 9px; font-weight: 700; letter-spacing: 1px; overflow: elide; }
            Text { text: summary; color: #e8f0fe; font-size: 13px; font-weight: 600; overflow: elide; }
            if body != "": Text { text: body; color: #8899bb; font-size: 11px; overflow: elide; }
            if actions.length > 0: HorizontalLayout {
                spacing: 6px; padding-top: 6px;
                for act in actions: Rectangle {
                    height: 24px; min-width: 64px; border-radius: 6px;
                    background: #1a2540; border-width: 1px; border-color: accent;
                    animate background { duration: 100ms; }
                    states [ hovered when at.has-hover: { background: #243050; } ]
                    at := TouchArea { clicked => { root.action-invoked(root.nid, act.key); } }
                    Text { text: act.label; color: accent; font-size: 10px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        Rectangle {
            width: 24px; height: 24px; border-radius: 12px; background: transparent;
            animate background { duration: 100ms; }
            states [ hovered when xt.has-hover: { background: #ff475720; } ]
            xt := TouchArea { clicked => { root.dismissed(root.nid); } }
            Text { text: "✕"; color: #4a5d80; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}

// ── Wewnętrzny rząd centrum ───────────────────────────────
component NotifRow inherits Rectangle {
    callback dismiss(int);
    in property <int>    nid;
    in property <string> app-name;
    in property <string> summary;
    in property <string> body;
    in property <string> age;
    in property <color>  accent:   #3d8ef0;
    in property <bool>   critical: false;

    height: body == "" ? 68px : 84px;
    border-radius: 10px; background: #0d1420;
    border-width: 1px; border-color: critical ? #ff475730 : #1e2d4a;
    clip: true;
    animate background { duration: 100ms; }
    states [ hovered when nh.has-hover: { background: #111922; } ]
    nh := TouchArea {}

    Rectangle { x: 0; y: 0; width: 3px; height: 100%; background: accent; border-radius: 2px; }

    HorizontalLayout {
        padding-left: 14px; padding-right: 10px; padding-top: 10px; padding-bottom: 10px; spacing: 10px;
        Rectangle {
            width: 32px; height: 32px; border-radius: 8px; background: #1a2540; border-width: 1px; border-color: #1e2d4a;
            Text { text: "●"; color: accent; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
        }
        VerticalLayout {
            horizontal-stretch: 1; alignment: start; spacing: 2px;
            HorizontalLayout {
                Text { text: app-name; color: #5a6d8a; font-size: 9px; font-weight: 700; letter-spacing: 1px; overflow: elide; }
                Rectangle { horizontal-stretch: 1; }
                Text { text: age; color: #2a3a55; font-size: 10px; }
            }
            Text { text: summary; color: #e8f0fe; font-size: 12px; font-weight: 600; overflow: elide; }
            if body != "": Text { text: body; color: #8899bb; font-size: 11px; overflow: elide; }
        }
        Rectangle {
            width: 20px; height: 20px; border-radius: 10px; background: transparent;
            animate background { duration: 100ms; }
            states [ hovered when dh.has-hover: { background: #ff475720; } ]
            dh := TouchArea { clicked => { root.dismiss(root.nid); } }
            Text { text: "✕"; color: #2a3a55; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}

// ═══════════════════════════════════════════════════════════
// NotificationCenter — osobne okno historii
// Rust struct: CenterItem { id, app_name, summary, body, age, accent, critical }
// ═══════════════════════════════════════════════════════════
export component NotificationCenter inherits Window {
    title: "Centrum powiadomień";
    background: #0a0e17;
    no-frame: true;
    always-on-top: true;
    width: 400px;
    height: 800px;

    callback close-panel();
    callback dismiss(int);
    callback clear-all();

    in property <[CenterItem]> items: [];

    Rectangle {
        width: 100%; height: 100%;
        background: @linear-gradient(180deg, #0a0e17 0%, #070c14 100%);
        border-width: 1px; border-color: #1e2d4a;

        Rectangle { y: 0; width: 100%; height: 1px; background: @linear-gradient(90deg, transparent 0%, #3d8ef044 50%, transparent 100%); }

        VerticalLayout {
            padding: 20px; spacing: 14px;

            HorizontalLayout {
                spacing: 8px;
                Text { text: "🔔"; font-size: 17px; vertical-alignment: center; }
                Text { text: "Powiadomienia"; color: #e8f0fe; font-size: 17px; font-weight: 300; vertical-alignment: center; }
                if items.length > 0: Text { text: "(" + items.length + ")"; color: #3d8ef0; font-size: 13px; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                if items.length > 0: Rectangle {
                    height: 28px; min-width: 76px; border-radius: 7px; background: #141c2e; border-width: 1px; border-color: #1e2d4a;
                    animate background { duration: 100ms; }
                    states [ hovered when ch.has-hover: { background: #1e2d4a; } ]
                    ch := TouchArea { clicked => { root.clear-all(); } }
                    Text { text: "Wyczyść"; color: #8899bb; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 28px; height: 28px; border-radius: 7px; background: transparent;
                    animate background { duration: 100ms; }
                    states [ hovered when cx.has-hover: { background: #1a2540; } ]
                    cx := TouchArea { clicked => { root.close-panel(); } }
                    Text { text: "✕"; color: #8899bb; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }

            Rectangle { height: 1px; background: #1e2d4a; }

            if items.length == 0: Rectangle {
                height: 200px;
                VerticalLayout {
                    alignment: center; spacing: 10px;
                    Text { text: "✓"; color: #1e2d4a; font-size: 52px; horizontal-alignment: center; }
                    Text { text: "Brak powiadomień"; color: #3a4d6a; font-size: 14px; horizontal-alignment: center; }
                }
            }

            if items.length > 0: Rectangle {
                vertical-stretch: 1; clip: true;
                ScrollView {
                    VerticalLayout {
                        spacing: 8px; padding-bottom: 8px;
                        for n in items: NotifRow {
                            nid: n.id; app-name: n.app-name; summary: n.summary;
                            body: n.body; age: n.age; accent: n.accent; critical: n.critical;
                            dismiss(id) => { root.dismiss(id); }
                        }
                    }
                }
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════
// NotificationOverlay — pełnoekranowe okno z popupami
// Rust struct: PopupItem { nid, app_name, summary, body, accent, critical, actions }
//              ActionItem { key, label }
// ═══════════════════════════════════════════════════════════
export component NotificationOverlay inherits Window {
    title: "Blue Notifications";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    width: 1920px;
    height: 1080px;

    callback popup-dismissed(int);
    callback popup-action(int, string);
    callback open-center();

    in property <[PopupItem]> popups: [];
    in property <int> unread-count: 0;

    VerticalLayout {
        x: parent.width - 376px;
        y: parent.height - 560px;
        spacing: 8px;
        alignment: end;

        for p in popups: NotificationPopup {
            nid: p.nid; app-name: p.app-name; summary: p.summary;
            body: p.body; accent: p.accent; critical: p.critical; actions: p.actions;
            dismissed(id)           => { root.popup-dismissed(id); }
            action-invoked(id, key) => { root.popup-action(id, key); }
        }

        if unread-count > 3: Rectangle {
            width: 360px; height: 36px; border-radius: 10px;
            background: #0d1420dd; border-width: 1px; border-color: #1e2d4a;
            animate background { duration: 100ms; }
            states [ hovered when mt.has-hover: { background: #111820dd; } ]
            mt := TouchArea { clicked => { root.open-center(); } }
            HorizontalLayout {
                padding-left: 14px; padding-right: 14px; spacing: 8px;
                Text { text: "+" + (unread-count - 3) + " więcej"; color: #3d8ef0; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                Text { text: "— kliknij aby otworzyć centrum"; color: #5a6d8a; font-size: 11px; vertical-alignment: center; }
            }
        }
    }
}
